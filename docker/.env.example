# ============================================================
# 智慧化管理系統 - Docker 環境設定
# 複製此檔案為 .env 並修改設定值
# ============================================================

# Docker Image (預設使用 GitHub Container Registry)
CUSTOM_IMAGE=ghcr.io/tiimlin/smart-management-system
CUSTOM_TAG=latest
PULL_POLICY=always

# 資料庫密碼（必填）
DB_PASSWORD=change_me_strong_password

# 外部資料庫（留空使用內建 MariaDB）
DB_HOST=
DB_PORT=

# 外部 Redis（留空使用內建 Redis）
REDIS_CACHE=
REDIS_QUEUE=

# HTTP/HTTPS 埠號
HTTP_PUBLISH_PORT=8080
# HTTPS_PUBLISH_PORT=443

# Frappe Site 設定
# 若要透過 127.0.0.1 訪問名為 mysite 的站台，設定為 mysite
FRAPPE_SITE_NAME_HEADER=

# Let's Encrypt (HTTPS)
LETSENCRYPT_EMAIL=your@email.com

# Nginx 設定
PROXY_READ_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m
UPSTREAM_REAL_IP_ADDRESS=127.0.0.1
UPSTREAM_REAL_IP_HEADER=X-Forwarded-For
UPSTREAM_REAL_IP_RECURSIVE=off

# Restart Policy
RESTART_POLICY=unless-stopped
